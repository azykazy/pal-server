# このファイルを terraform.tfvars にコピーして値を埋める (terraform.tfvars は gitignore 済み)

# パルワールド専用アカウントのサブスクリプション ID (`az account show --query id -o tsv`)
subscription_id = "00000000-0000-0000-0000-000000000000"

# SSH 公開鍵の中身 (例: `cat ~/.ssh/id_ed25519.pub` の出力)
ssh_public_key = "ssh-ed25519 AAAA... you@example.com"

# SSH を許可する CIDR (自宅のグローバル IP)。空文字なら SSH 非開放 (通常運用では不要)
allowed_ssh_cidr = ""

# Palworld サーバー設定 (パスワードは英数字のみ)
server_name             = "My Palworld Server"
server_password         = "changeMe123"
palworld_admin_password = "changeMeAdmin456"

# Discord アプリケーション情報 (docs/SETUP.md 参照)
discord_public_key     = "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
discord_application_id = "123456789012345678"

# 自動停止などの通知先 Discord Webhook (チャンネル設定 → 連携サービス → ウェブフック)
discord_webhook_url = "https://discord.com/api/webhooks/..."
