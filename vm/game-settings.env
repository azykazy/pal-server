# Palworld ゲームバランス設定
# このファイルを編集して `mise run seed-secrets` を実行すると Blob Storage に反映される。
# VM は起動時にこのファイルを読み込み、次回 docker compose 起動に適用する。
# 個別変更: mise run update-config -- game-setting <KEY> <VALUE>

# 経験値・捕獲・出現数
# 出現数は 2 以上にするとボスが 2 体になるので 1 のまま
EXP_RATE=3.000000
PAL_CAPTURE_RATE=2.000000
PAL_SPAWN_NUM_RATE=1.000000

# プレイヤーダメージ (与える 1.5x = これ以上はぬるい / 受ける 0.8x = 少し硬め)
PLAYER_DAMAGE_RATE_ATTACK=1.500000
PLAYER_DAMAGE_RATE_DEFENSE=0.800000

# パルダメージ (等倍)
PAL_DAMAGE_RATE_ATTACK=1.000000
PAL_DAMAGE_RATE_DEFENSE=1.000000

# 満腹度・スタミナ消費 (値が低いほど減りにくい)
# PLAYER_STOMACH_DECREASE_RATE=0.3 で序盤の飢餓を防げる
# PAL_STAMINA_DECREASE_RATE=0.4 で実質 2.5x のスタミナ
PLAYER_STOMACH_DECREASE_RATE=0.300000
PAL_STAMINA_DECREASE_RATE=0.400000

# 自然回復 (通常 3x / 睡眠中 5x)
PLAYER_AUTO_HP_REGENE_RATE=3.000000
PLAYER_AUTO_HP_REGENE_RATE_IN_SLEEP=5.000000
PAL_AUTO_HP_REGENE_RATE=3.000000
PAL_AUTO_HP_REGENE_RATE_IN_SLEEP=5.000000

# 建築物へのダメージ (0 = 破壊なし)
BUILD_OBJECT_DAMAGE_RATE=0.000000

# 採取: ドロップ量 2x / オブジェクト HP 0.5x (壊しやすい) / リスポーン等倍
COLLECTION_DROP_RATE=2.000000
COLLECTION_OBJECT_HP_RATE=0.500000
COLLECTION_OBJECT_RESPAWN_SPEED_RATE=1.000000

# エネミードロップ 2x
ENEMY_DROP_ITEM_RATE=2.000000

# 装備品耐久度 (0 = 劣化なし / 0.7 = 適度)
EQUIPMENT_DURABILITY_DECREASE_RATE=0.000000

# 隕石 (MinInterval の "M" は Minimum の略、単位: 分)
MIN_INTERVAL_OF_METEOR=15

# 卵孵化時間 (0 = 即時)
PAL_EGG_DEFAULT_HATCHING_TIME=0.000000

# 拠点作業パル最大数 (重要: 稼働中は変更しないこと)
BASE_CAMP_WORKER_MAX_NUM=25

# グローバルパルボックス (全員でパルストレージを共有)
SHARED_PAL_STORAGE=true

# 侵攻イベント (夜の襲撃) / プレデターボスパル
ENABLE_INVADER_ENEMY=true
ENABLE_PREDATOR_BOSS_PAL=true
